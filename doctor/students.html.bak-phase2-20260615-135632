<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>طلابي - لوحة الدكتورة</title>
  <link rel="stylesheet" href="/assets/css/main.css">
  <link rel="stylesheet" href="/assets/css/admin.css">
</head>
<body>
  <div id="doctor-login-overlay" class="modal-overlay" style="display:none">
    <div class="modal-box" style="max-width:420px">
      <div class="modal-header"><h3>دخول لوحة الدكتورة / الباقة</h3></div>
      <div class="modal-body">
        <p class="text-muted mb-2">أدخل كود الدخول للمتابعة</p>
        <div class="form-group"><input id="doctor-code" type="password" placeholder="كود الدخول" autocomplete="off"></div>
        <div id="doctor-login-message" class="text-red text-sm mb-1"></div>
        <button id="doctor-login-btn" class="btn btn-primary btn-block">دخول</button>
      </div>
    </div>
  </div>

  <div id="doctor-app" class="admin-shell" style="display:none">
    <nav class="admin-sidebar">
      <div class="sidebar-header"><div class="brand">دوري المذاكراوية <span>طلابي - لوحة الدكتورة</span></div></div>
      <div class="sidebar-nav" id="doctor-nav"></div>
    </nav>
    <main class="admin-main">
      <div class="admin-topbar"><h1>طلابي - لوحة الدكتورة</h1></div>
      <div class="admin-content">
        <div id="students-message" class="mb-1"></div>
        <div class="card mb-2"><div class="card-title">➕ إضافة طالب موجود للمجموعة</div><div class="input-row"><input id="add-student-phone" placeholder="رقم الهاتف"><button id="add-student-btn" class="btn btn-primary">إضافة للمجموعة</button></div></div>
        <div class="table-wrap"><table><thead><tr><th>الاسم</th><th>الهاتف</th><th>الصف</th><th>النظام</th><th>المسار</th><th>النقاط</th><th>XP</th><th>الحالة</th><th>إجراءات</th></tr></thead><tbody id="my-students-body"></tbody></table></div>
        <div id="points-modal" class="modal-overlay hidden" style="display:none"><div class="modal-box"><div class="modal-header"><h3>تعديل نقاط الطالب</h3><button data-close-modal="points-modal" class="btn btn-ghost">×</button></div><div class="modal-body"><input type="hidden" id="points-student-id"><div class="form-group"><label class="form-label">الطالب</label><input id="points-student-name" disabled></div><div class="form-group"><label class="form-label">النقاط</label><input type="number" id="points-amount"></div><div class="form-group"><label class="form-label">السبب</label><input id="points-reason"></div><div class="form-group"><label class="form-label">العملية</label><select id="points-operation"><option value="add">إضافة</option><option value="subtract">خصم</option></select></div><button id="save-points-btn" class="btn btn-primary">حفظ</button></div></div></div>
      </div>
    </main>
  </div>

  <div id="toast-container"></div>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="/assets/js/supabase.js"></script>
  <script src="/assets/js/utils.js"></script>
  <script src="/assets/js/doctor-panel.js"></script>
  <script>document.addEventListener('DOMContentLoaded', initDoctorStudents);</script>
</body>
</html>
