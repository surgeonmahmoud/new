<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>تقارير المنصة - دكتور زياد</title>
  <link rel="stylesheet" href="/assets/css/main.css">
  <link rel="stylesheet" href="/assets/css/admin.css">
</head>
<body>
  <div id="ziad-login-overlay" class="modal-overlay" style="display:none">
    <div class="modal-box" style="max-width:420px">
      <div class="modal-header"><h3>لوحة كنترول دكتور زياد - المدير</h3></div>
      <div class="modal-body">
        <p class="text-muted mb-2">أدخل كود الدخول للمتابعة</p>
        <div class="form-group"><input id="ziad-code" type="password" placeholder="كود الدخول" autocomplete="off"></div>
        <div id="ziad-login-error" class="text-red text-sm mb-1"></div>
        <button id="ziad-login-btn" class="btn btn-primary btn-block">دخول</button>
      </div>
    </div>
  </div>

  <div id="ziad-app" class="admin-shell" style="display:none">
    <nav class="admin-sidebar">
      <div class="sidebar-header"><div class="brand">دوري المذاكراوية <span>تقارير المنصة - دكتور زياد</span></div></div>
      <div class="sidebar-nav" id="ziad-nav"></div>
    </nav>
    <main class="admin-main">
      <div class="admin-topbar"><h1>تقارير المنصة - دكتور زياد</h1></div>
      <div class="admin-content">
        <div class="filter-bar">
          <div class="form-group"><label class="form-label">من</label><input type="date" id="filter-date-from"></div>
          <div class="form-group"><label class="form-label">إلى</label><input type="date" id="filter-date-to"></div>
          <div class="form-group"><label class="form-label">الدكتورة</label><select id="filter-doctor"><option value="">كل المجموعات</option></select></div>
          <div class="form-group"><label class="form-label">المادة</label><select id="filter-subject"><option value="">كل المواد</option></select></div>
          <div class="form-group"><label class="form-label">الحالة</label><select id="filter-status"><option value="">كل الحالات</option></select></div>
        </div>
        <div class="table-wrap"><table><thead><tr><th>التاريخ</th><th>الطالب</th><th>الدكتورة</th><th>المادة</th><th>النشاط</th><th>الكمية</th><th>الساعات</th><th>النقاط</th><th>الحالة</th></tr></thead><tbody id="reports-table-body"></tbody></table></div>
      </div>
    </main>
  </div>

  <div id="toast-container"></div>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="/assets/js/supabase.js"></script>
  <script src="/assets/js/utils.js"></script>
  <script src="/assets/js/ziad-panel.js"></script>
  <script>document.addEventListener('DOMContentLoaded', initZiadReports);</script>
</body>
</html>
