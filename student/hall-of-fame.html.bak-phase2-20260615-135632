<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="/assets/js/supabase.js"></script>
<script src="/assets/js/utils.js"></script>
<script>
const HOF_CATEGORIES = [
  { key: 'general',    label: 'بطل الدوري',      badge: '🥇', field: 'total_score',     suffix: 'نقطة',   view: 'v_leaderboard_general' },
  { key: 'questions',  label: 'هداف الدوري',     badge: '🎯', field: 'total_questions',  suffix: 'سؤال',  view: 'v_leaderboard_questions' },
  { key: 'focus',      label: 'بطل التركيز',     badge: '⚡', field: 'operation_minutes',suffix: 'دقيقة', view: 'v_leaderboard_focus' },
  { key: 'persistent', label: 'المثابر',          badge: '📚', field: 'total_study_hours',suffix: 'ساعة', view: 'v_leaderboard_persistent' },
  { key: 'streak',     label: 'حارس السلسلة',    badge: '🔥', field: 'current_streak',   suffix: 'يوم',  view: null },
];

document.addEventListener('DOMContentLoaded', async () => {
  requireStudentAuth();
  initNavToggle();
  const db = window.supabaseClient;
  const container = qs('#hofContainer');

  const results = [];

  for (const cat of HOF_CATEGORIES) {
    try {
      let top = null;
      if (cat.view) {
        const { data } = await db.from(cat.view)
          .select('student_name,' + cat.field)
          .order(cat.field, { ascending: false })
          .limit(1)
          .maybeSingle();
        top = data;
      } else if (cat.key === 'streak') {
        const { data } = await db.from('students')
          .select('name, current_streak')
          .order('current_streak', { ascending: false })
          .limit(1)
          .maybeSingle();
        if (data) top = { student_name: data.name, current_streak: data.current_streak };
      }
      results.push({ cat, top });
    } catch {
      results.push({ cat, top: null });
    }
  }

  if (results.every(r => !r.top)) {
    container.innerHTML = emptyHtml('Hall of Fame فاضل… ابدأ المذاكرة واملاه! 💪');
    return;
  }

  container.innerHTML = `
    <div style="text-align:center;margin-bottom:24px">
      <div style="font-family:var(--font-display);font-size:1.3rem;font-weight:800;color:var(--gold)">أبطال الدوري</div>
      <p class="text-muted" style="font-size:0.85rem;margin-top:4px">أكثر الطلاب تميزاً على المنصة</p>
    </div>
    <div class="hof-grid">
      ${results.map(({ cat, top }) => {
        if (!top) return `
          <div class="hof-card">
            <div class="hof-badge">${cat.badge}</div>
            <div class="hof-category">${cat.label}</div>
            <div class="hof-name" style="color:var(--text-muted);font-size:0.85rem">ما اتحددش بعد</div>
          </div>`;
        const val = top[cat.field] ?? 0;
        return `
          <div class="hof-card">
            <div class="hof-badge">${cat.badge}</div>
            <div class="hof-category">${cat.label}</div>
            <div class="hof-name">${safeText(top.student_name)}</div>
            <div class="hof-value">${formatNumber(val)} ${cat.suffix}</div>
          </div>`;
      }).join('')}
    </div>`;
});
</script>
<a href="https://t.me/Mahmoud_M_Hassan101BOT" class="support-float" data-support-link aria-label="support">💬</a>
</body>
</html>
