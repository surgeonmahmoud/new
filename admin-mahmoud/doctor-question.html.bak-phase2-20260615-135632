<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>سؤال الدكتور — دوري المذاكراوية</title>
  <link rel="stylesheet" href="/assets/css/main.css">
  <link rel="stylesheet" href="/assets/css/admin.css">
</head>
<body>

<div id="admin-login-overlay">
  <div class="login-card">
    <div class="logo">🏆</div>
    <h2>دوري المذاكراوية</h2>
    <p>لوحة تحكم الأدمن — محمود</p>
    <div class="form-group">
      <input type="password" id="login-code-input" placeholder="أدخل كود الدخول" autocomplete="off">
    </div>
    <button id="login-btn" class="btn btn-primary btn-block btn-lg">دخول</button>
  </div>
</div>

<div class="admin-shell">
  <nav class="admin-sidebar">
    <div class="sidebar-header">
      <div class="brand">دوري المذاكراوية <span>Admin — محمود</span></div>
    </div>
    <div class="sidebar-nav" id="admin-nav"></div>
    <div class="sidebar-footer">
      <button id="admin-logout-btn" class="btn btn-ghost btn-sm btn-block">🚪 خروج</button>
    </div>
  </nav>

  <main class="admin-main">
    <div class="admin-topbar">
      <h1>❓ سؤال الدكتور</h1>
      <button class="btn btn-primary btn-sm" onclick="openAddQuestion()">➕ سؤال جديد</button>
    </div>

    <div class="admin-content">

      <!-- Today's Question Display -->
      <div id="question-display" class="mb-2">
        <div class="spinner"></div>
      </div>

      <!-- Answers Section -->
      <div id="answers-section" style="display:none">
        <div class="section-header">
          <h2>💬 الإجابات</h2>
        </div>
        <div id="answers-list">
          <div class="spinner"></div>
        </div>
      </div>

    </div>
  </main>
</div>

<!-- Question Form Modal -->
<div id="question-form-modal" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h3 id="question-modal-title">➕ سؤال جديد</h3>
      <button data-close-modal class="btn btn-ghost btn-xs">✕</button>
    </div>
    <div class="modal-body">
      <form id="question-form">
        <div class="form-group">
          <label class="form-label">نص السؤال</label>
          <textarea name="question_text" rows="4" required placeholder="اكتب سؤال الدكتور هنا..."></textarea>
        </div>
        <div class="input-row">
          <div class="form-group">
            <label class="form-label">الصف المستهدف</label>
            <input type="text" name="target_grade" placeholder="الكل (اتركه فارغاً)">
          </div>
          <div class="form-group">
            <label class="form-label">النظام المستهدف</label>
            <input type="text" name="target_edu_system" placeholder="الكل">
          </div>
          <div class="form-group">
            <label class="form-label">التتبع المستهدف</label>
            <input type="text" name="target_track" placeholder="الكل">
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-block mt-2">💾 حفظ السؤال</button>
      </form>
    </div>
  </div>
</div>

<div id="toast-container"></div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="/assets/js/supabase.js"></script>
<script src="/assets/js/utils.js"></script>
<script src="/assets/js/admin-mahmoud.js"></script>
<script>
  window._adminInitFn = initMahmoudDoctorQuestion;
  document.addEventListener('DOMContentLoaded', () => {
    if (checkAccess()) initMahmoudDoctorQuestion();
  });
</script>
</body>
</html>
