<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>إدارة الطلاب — دوري المذاكراوية</title>
  <link rel="stylesheet" href="/assets/css/main.css">
  <link rel="stylesheet" href="/assets/css/admin.css">
</head>
<body>

<div id="admin-login-overlay">
  <div class="login-card">
    <div class="logo">🏆</div>
    <h2>دوري المذاكراوية</h2>
    <p>لوحة تحكم الأدمن — محمود</p>
    <div class="form-group">
      <input type="password" id="login-code-input" placeholder="أدخل كود الدخول" autocomplete="off">
    </div>
    <button id="login-btn" class="btn btn-primary btn-block btn-lg">دخول</button>
  </div>
</div>

<div class="admin-shell">
  <nav class="admin-sidebar">
    <div class="sidebar-header">
      <div class="brand">دوري المذاكراوية <span>Admin — محمود</span></div>
    </div>
    <div class="sidebar-nav" id="admin-nav"></div>
    <div class="sidebar-footer">
      <button id="admin-logout-btn" class="btn btn-ghost btn-sm btn-block">🚪 خروج</button>
    </div>
  </nav>

  <main class="admin-main">
    <div class="admin-topbar">
      <h1>👥 إدارة الطلاب</h1>
      <span id="students-count" class="topbar-badge">—</span>
    </div>

    <div class="admin-content">

      <!-- Filters -->
      <div class="filter-bar">
        <div class="form-group">
          <label class="form-label">بحث</label>
          <input type="text" id="students-search" placeholder="اسم أو هاتف...">
        </div>
        <div class="form-group">
          <label class="form-label">الصف</label>
          <select id="filter-grade">
            <option value="">الكل</option>
            <option>أولى ثانوي</option>
            <option>ثانية ثانوي</option>
            <option>ثالثة ثانوي</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">النظام</label>
          <select id="filter-edu">
            <option value="">الكل</option>
            <option>مصري</option>
            <option>أزهري</option>
            <option>دولي</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">الحالة</label>
          <select id="filter-status">
            <option value="">الكل</option>
            <option value="active">فعّال</option>
            <option value="frozen">مجمد</option>
            <option value="inactive">معطّل</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">الدكتور</label>
          <input type="text" id="filter-doctor" placeholder="اسم الدكتور...">
        </div>
        <div class="form-group" style="align-self:flex-end">
          <button id="students-filter-btn" class="btn btn-primary">🔍 بحث</button>
        </div>
      </div>

      <!-- Table -->
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>الاسم</th>
              <th>الهاتف</th>
              <th>الصف</th>
              <th>النظام</th>
              <th>التتبع</th>
              <th>الدكتور</th>
              <th>النقاط</th>
              <th>XP</th>
              <th>الحالة</th>
              <th>إجراءات</th>
            </tr>
          </thead>
          <tbody id="students-tbody">
            <tr class="loading-row"><td colspan="10"><div class="spinner"></div></td></tr>
          </tbody>
        </table>
      </div>

    </div>
  </main>
</div>

<!-- Edit Student Modal -->
<div id="student-modal" class="modal-overlay hidden">
  <div class="modal-box">
    <div class="modal-header">
      <h3>✏️ تعديل بيانات: <span id="modal-student-name"></span></h3>
      <button data-close-modal class="btn btn-ghost btn-xs">✕</button>
    </div>
    <div class="modal-body">
      <form id="student-edit-form">
        <div class="input-row">
          <div class="form-group">
            <label class="form-label">الاسم</label>
            <input type="text" name="name" required>
          </div>
          <div class="form-group">
            <label class="form-label">الهاتف</label>
            <input type="tel" name="phone">
          </div>
          <div class="form-group">
            <label class="form-label">الصف</label>
            <input type="text" name="grade_level">
          </div>
          <div class="form-group">
            <label class="form-label">النظام التعليمي</label>
            <input type="text" name="edu_system">
          </div>
          <div class="form-group">
            <label class="form-label">التتبع</label>
            <input type="text" name="track">
          </div>
          <div class="form-group">
            <label class="form-label">الدكتور</label>
            <input type="text" name="doctor_group">
          </div>
          <div class="form-group">
            <label class="form-label">PIN جديد (اتركه فارغ إذا لم ترد تغييره)</label>
            <input type="text" name="pin_hash" autocomplete="new-password">
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-block mt-2">💾 حفظ التعديلات</button>
      </form>
    </div>
  </div>
</div>

<!-- Points Modal -->
<div id="points-modal" class="modal-overlay hidden">
  <div class="modal-box" style="max-width:400px">
    <div class="modal-header">
      <h3>💰 إضافة / خصم نقاط</h3>
      <button data-close-modal class="btn btn-ghost btn-xs">✕</button>
    </div>
    <div class="modal-body">
      <p class="mb-1">الطالب: <strong id="points-student-name"></strong></p>
      <input type="hidden" id="points-student-id">
      <div class="form-group">
        <label class="form-label">العملية</label>
        <select id="points-op">
          <option value="add">إضافة ➕</option>
          <option value="subtract">خصم ➖</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">عدد النقاط</label>
        <input type="number" id="points-amount" min="1" placeholder="مثال: 50">
      </div>
      <div class="form-group">
        <label class="form-label">السبب</label>
        <input type="text" id="points-reason" placeholder="سبب التعديل...">
      </div>
      <button class="btn btn-primary btn-block" onclick="submitPoints()">✅ تأكيد</button>
    </div>
  </div>
</div>

<!-- Profile Modal -->
<div id="profile-modal" class="modal-overlay hidden">
  <div class="modal-box modal-xl">
    <div class="modal-header">
      <h3>👁 ملف الطالب</h3>
      <button data-close-modal class="btn btn-ghost btn-xs">✕</button>
    </div>
    <div class="modal-body" id="profile-content">
      <div class="spinner"></div>
    </div>
  </div>
</div>

<div id="toast-container"></div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="/assets/js/supabase.js"></script>
<script src="/assets/js/utils.js"></script>
<script src="/assets/js/admin-mahmoud.js"></script>
<script>
  window._adminInitFn = initMahmoudStudents;
  document.addEventListener('DOMContentLoaded', () => {
    if (checkAccess()) initMahmoudStudents();
  });
</script>
</body>
</html>
