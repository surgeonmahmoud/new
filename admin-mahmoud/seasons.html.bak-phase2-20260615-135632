<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>المواسم — دوري المذاكراوية</title>
  <link rel="stylesheet" href="/assets/css/main.css">
  <link rel="stylesheet" href="/assets/css/admin.css">
</head>
<body>

<div id="admin-login-overlay">
  <div class="login-card">
    <div class="logo">🏆</div>
    <h2>دوري المذاكراوية</h2>
    <p>لوحة تحكم الأدمن — محمود</p>
    <div class="form-group">
      <input type="password" id="login-code-input" placeholder="أدخل كود الدخول" autocomplete="off">
    </div>
    <button id="login-btn" class="btn btn-primary btn-block btn-lg">دخول</button>
  </div>
</div>

<div class="admin-shell">
  <nav class="admin-sidebar">
    <div class="sidebar-header">
      <div class="brand">دوري المذاكراوية <span>Admin — محمود</span></div>
    </div>
    <div class="sidebar-nav" id="admin-nav"></div>
    <div class="sidebar-footer">
      <button id="admin-logout-btn" class="btn btn-ghost btn-sm btn-block">🚪 خروج</button>
    </div>
  </nav>

  <main class="admin-main">
    <div class="admin-topbar">
      <h1>🏆 المواسم</h1>
      <button class="btn btn-primary btn-sm" onclick="openModal('new-season-modal')">➕ موسم جديد</button>
    </div>

    <div class="admin-content">

      <div class="section-header">
        <h2>المواسم الحالية والسابقة</h2>
      </div>

      <div id="seasons-list" class="mb-2">
        <div class="spinner"></div>
      </div>

      <hr class="divider">

      <div class="section-header">
        <h2>📦 الأرشيف</h2>
      </div>

      <div id="archives-list">
        <div class="spinner"></div>
      </div>

    </div>
  </main>
</div>

<!-- New Season Modal -->
<div id="new-season-modal" class="modal-overlay hidden">
  <div class="modal-box" style="max-width:420px">
    <div class="modal-header">
      <h3>➕ موسم جديد</h3>
      <button data-close-modal class="btn btn-ghost btn-xs">✕</button>
    </div>
    <div class="modal-body">
      <p class="text-sm text-muted mb-2">إنشاء موسم جديد سيوقف الموسم الحالي تلقائياً.</p>
      <form id="new-season-form">
        <div class="form-group">
          <label class="form-label">اسم الموسم</label>
          <input type="text" name="season_name" required placeholder="مثال: الموسم الثاني 2025">
        </div>
        <div class="form-group">
          <label class="form-label">تاريخ البداية</label>
          <input type="date" name="starts_at">
        </div>
        <button type="submit" class="btn btn-primary btn-block mt-2">🚀 بدء الموسم</button>
      </form>
    </div>
  </div>
</div>

<div id="toast-container"></div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="/assets/js/supabase.js"></script>
<script src="/assets/js/utils.js"></script>
<script src="/assets/js/admin-mahmoud.js"></script>
<script>
  window._adminInitFn = initMahmoudSeasons;
  document.addEventListener('DOMContentLoaded', () => {
    if (checkAccess()) initMahmoudSeasons();
  });
</script>
</body>
</html>
