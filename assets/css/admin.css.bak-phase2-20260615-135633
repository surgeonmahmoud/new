/* =====================================================
   دوري المذاكراوية — Admin Panel CSS (Part 2)
   Dark RTL Admin Theme
   ===================================================== */

@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap');

:root {
  /* Core Palette */
  --bg-base:        #0d0f14;
  --bg-surface:     #13161e;
  --bg-card:        #1a1e2a;
  --bg-card-hover:  #1f2436;
  --bg-input:       #10121a;
  --bg-modal:       #161926;

  /* Accent — Premier League Purple/Teal */
  --accent-primary: #7c3aed;
  --accent-glow:    rgba(124, 58, 237, 0.25);
  --accent-teal:    #0ea5e9;
  --accent-gold:    #f59e0b;
  --accent-green:   #10b981;
  --accent-red:     #ef4444;
  --accent-orange:  #f97316;

  /* Text */
  --text-primary:   #e8eaf2;
  --text-secondary: #8892a4;
  --text-muted:     #4a5568;
  --text-accent:    #a78bfa;

  /* Borders */
  --border-soft:    rgba(255,255,255,0.06);
  --border-medium:  rgba(255,255,255,0.12);
  --border-accent:  rgba(124, 58, 237, 0.4);

  /* Status */
  --status-pending:  #f59e0b;
  --status-approved: #10b981;
  --status-rejected: #ef4444;
  --status-frozen:   #0ea5e9;

  /* Spacing */
  --radius-sm:  6px;
  --radius-md:  10px;
  --radius-lg:  16px;
  --radius-xl:  22px;

  /* Shadows */
  --shadow-card:  0 4px 24px rgba(0,0,0,0.4);
  --shadow-modal: 0 20px 60px rgba(0,0,0,0.7);
  --shadow-glow:  0 0 20px var(--accent-glow);

  /* Layout */
  --sidebar-width: 220px;
  --topbar-height: 60px;

  --font-main: 'Cairo', sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { direction: rtl; font-size: 15px; }

body {
  font-family: var(--font-main);
  background: var(--bg-base);
  color: var(--text-primary);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── Login Gate ── */
#admin-login-overlay {
  position: fixed; inset: 0; z-index: 9999;
  background: var(--bg-base);
  display: flex; align-items: center; justify-content: center;
}

.login-card {
  background: var(--bg-card);
  border: 1px solid var(--border-accent);
  border-radius: var(--radius-xl);
  padding: 2.5rem 2rem;
  width: min(400px, 90vw);
  box-shadow: var(--shadow-modal), var(--shadow-glow);
  text-align: center;
}

.login-card .logo {
  font-size: 2.4rem; margin-bottom: .25rem;
}

.login-card h2 {
  font-size: 1.3rem; font-weight: 700;
  color: var(--text-accent); margin-bottom: .25rem;
}

.login-card p {
  font-size: .85rem; color: var(--text-secondary); margin-bottom: 1.5rem;
}

/* ── Shell Layout ── */
.admin-shell {
  display: flex; min-height: 100vh;
}

/* ── Sidebar ── */
.admin-sidebar {
  width: var(--sidebar-width);
  background: var(--bg-surface);
  border-left: 1px solid var(--border-soft);
  display: flex; flex-direction: column;
  position: fixed; top: 0; right: 0; bottom: 0;
  z-index: 100;
  transition: transform .3s ease;
}

.sidebar-header {
  padding: 1.25rem 1rem;
  border-bottom: 1px solid var(--border-soft);
}

.sidebar-header .brand {
  font-size: 1rem; font-weight: 800;
  color: var(--text-accent);
  line-height: 1.3;
}

.sidebar-header .brand span {
  display: block; font-size: .72rem; color: var(--text-secondary); font-weight: 400;
}

.sidebar-nav {
  flex: 1; overflow-y: auto; padding: .75rem 0;
}

.sidebar-nav a {
  display: flex; align-items: center; gap: .65rem;
  padding: .65rem 1rem;
  color: var(--text-secondary);
  text-decoration: none;
  font-size: .82rem; font-weight: 500;
  transition: all .18s;
  border-right: 3px solid transparent;
}

.sidebar-nav a .nav-icon { font-size: 1rem; flex-shrink: 0; }

.sidebar-nav a:hover {
  color: var(--text-primary);
  background: rgba(124,58,237,.1);
}

.sidebar-nav a.active {
  color: var(--text-accent);
  background: rgba(124,58,237,.15);
  border-right-color: var(--accent-primary);
}

.sidebar-footer {
  padding: .75rem 1rem;
  border-top: 1px solid var(--border-soft);
  font-size: .75rem; color: var(--text-muted);
}

/* ── Main Content ── */
.admin-main {
  margin-right: var(--sidebar-width);
  flex: 1; min-width: 0;
  display: flex; flex-direction: column;
}

.admin-topbar {
  height: var(--topbar-height);
  background: var(--bg-surface);
  border-bottom: 1px solid var(--border-soft);
  display: flex; align-items: center;
  padding: 0 1.5rem;
  position: sticky; top: 0; z-index: 50;
  gap: 1rem;
}

.admin-topbar h1 {
  font-size: 1.05rem; font-weight: 700;
  color: var(--text-primary); flex: 1;
}

.topbar-badge {
  background: var(--accent-primary);
  color: #fff; font-size: .72rem;
  padding: .15rem .55rem; border-radius: 20px;
  font-weight: 600;
}

.admin-content {
  padding: 1.5rem;
  flex: 1;
}

/* ── Cards ── */
.card {
  background: var(--bg-card);
  border: 1px solid var(--border-soft);
  border-radius: var(--radius-lg);
  padding: 1.25rem;
  box-shadow: var(--shadow-card);
}

.card-title {
  font-size: .9rem; font-weight: 700;
  color: var(--text-accent);
  margin-bottom: 1rem;
  display: flex; align-items: center; gap: .5rem;
}

/* ── Stat Cards ── */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 1rem;
  margin-bottom: 1.5rem;
}

.stat-card {
  background: var(--bg-card);
  border: 1px solid var(--border-soft);
  border-radius: var(--radius-md);
  padding: 1rem;
  text-align: center;
  transition: border-color .2s, transform .2s;
}

.stat-card:hover {
  border-color: var(--border-accent);
  transform: translateY(-2px);
}

.stat-card .stat-icon { font-size: 1.5rem; margin-bottom: .4rem; }

.stat-card .stat-value {
  font-size: 1.6rem; font-weight: 800;
  color: var(--text-accent);
  font-family: var(--font-mono);
}

.stat-card .stat-label {
  font-size: .75rem; color: var(--text-secondary);
  margin-top: .15rem;
}

/* ── Tables ── */
.table-wrap {
  overflow-x: auto;
  border-radius: var(--radius-md);
  border: 1px solid var(--border-soft);
}

table {
  width: 100%; border-collapse: collapse;
  font-size: .82rem;
}

thead th {
  background: var(--bg-surface);
  color: var(--text-secondary);
  font-weight: 600;
  padding: .7rem .9rem;
  text-align: right;
  border-bottom: 1px solid var(--border-soft);
  white-space: nowrap;
}

tbody tr {
  border-bottom: 1px solid var(--border-soft);
  transition: background .15s;
}

tbody tr:last-child { border-bottom: none; }
tbody tr:hover { background: var(--bg-card-hover); }

tbody td {
  padding: .65rem .9rem;
  color: var(--text-primary);
  vertical-align: middle;
}

.td-mono { font-family: var(--font-mono); font-size: .78rem; }

/* ── Badges ── */
.badge {
  display: inline-flex; align-items: center;
  padding: .18rem .55rem; border-radius: 20px;
  font-size: .72rem; font-weight: 600; white-space: nowrap;
}

.badge-green  { background: rgba(16,185,129,.15); color: #10b981; border: 1px solid rgba(16,185,129,.3); }
.badge-red    { background: rgba(239,68,68,.15);  color: #ef4444; border: 1px solid rgba(239,68,68,.3); }
.badge-yellow { background: rgba(245,158,11,.15); color: #f59e0b; border: 1px solid rgba(245,158,11,.3); }
.badge-blue   { background: rgba(14,165,233,.15); color: #0ea5e9; border: 1px solid rgba(14,165,233,.3); }
.badge-purple { background: rgba(124,58,237,.15); color: #a78bfa; border: 1px solid rgba(124,58,237,.3); }
.badge-gray   { background: rgba(74,85,104,.2);   color: #8892a4; border: 1px solid rgba(74,85,104,.3); }

/* ── Buttons ── */
.btn {
  display: inline-flex; align-items: center; gap: .4rem;
  padding: .5rem 1rem; border-radius: var(--radius-sm);
  font-family: var(--font-main); font-size: .82rem; font-weight: 600;
  cursor: pointer; border: 1px solid transparent;
  transition: all .18s; white-space: nowrap; text-decoration: none;
}

.btn:disabled { opacity: .45; cursor: not-allowed; }

.btn-primary {
  background: var(--accent-primary); color: #fff;
  border-color: var(--accent-primary);
}
.btn-primary:hover:not(:disabled) { background: #6d28d9; }

.btn-teal {
  background: rgba(14,165,233,.15); color: var(--accent-teal);
  border-color: rgba(14,165,233,.35);
}
.btn-teal:hover:not(:disabled) { background: rgba(14,165,233,.25); }

.btn-green {
  background: rgba(16,185,129,.15); color: var(--accent-green);
  border-color: rgba(16,185,129,.35);
}
.btn-green:hover:not(:disabled) { background: rgba(16,185,129,.25); }

.btn-red {
  background: rgba(239,68,68,.12); color: var(--accent-red);
  border-color: rgba(239,68,68,.3);
}
.btn-red:hover:not(:disabled) { background: rgba(239,68,68,.22); }

.btn-yellow {
  background: rgba(245,158,11,.12); color: var(--accent-gold);
  border-color: rgba(245,158,11,.3);
}
.btn-yellow:hover:not(:disabled) { background: rgba(245,158,11,.22); }

.btn-ghost {
  background: transparent; color: var(--text-secondary);
  border-color: var(--border-medium);
}
.btn-ghost:hover:not(:disabled) { color: var(--text-primary); border-color: var(--border-soft); }

.btn-sm { padding: .3rem .65rem; font-size: .76rem; }
.btn-xs { padding: .2rem .45rem; font-size: .7rem; }
.btn-lg { padding: .7rem 1.5rem; font-size: .9rem; }
.btn-block { width: 100%; justify-content: center; }

/* ── Form Elements ── */
.form-group { margin-bottom: 1rem; }

label.form-label {
  display: block; font-size: .8rem; font-weight: 600;
  color: var(--text-secondary); margin-bottom: .35rem;
}

input[type="text"],
input[type="number"],
input[type="password"],
input[type="date"],
input[type="datetime-local"],
input[type="time"],
input[type="url"],
input[type="tel"],
select, textarea {
  width: 100%;
  background: var(--bg-input);
  border: 1px solid var(--border-medium);
  color: var(--text-primary);
  border-radius: var(--radius-sm);
  padding: .55rem .8rem;
  font-family: var(--font-main); font-size: .83rem;
  transition: border-color .18s;
  outline: none;
}

input:focus, select:focus, textarea:focus {
  border-color: var(--accent-primary);
  box-shadow: 0 0 0 3px var(--accent-glow);
}

select { appearance: none; }

.input-row {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: .75rem;
}

/* ── Filter Bar ── */
.filter-bar {
  display: flex; flex-wrap: wrap; gap: .65rem;
  align-items: flex-end;
  margin-bottom: 1rem;
  padding: 1rem;
  background: var(--bg-surface);
  border: 1px solid var(--border-soft);
  border-radius: var(--radius-md);
}

.filter-bar .form-group { margin-bottom: 0; min-width: 140px; }
.filter-bar .form-group label { font-size: .73rem; }
.filter-bar input, .filter-bar select { font-size: .8rem; padding: .4rem .7rem; }

/* ── Modals ── */
.modal-overlay {
  position: fixed; inset: 0; z-index: 500;
  background: rgba(0,0,0,.75);
  display: flex; align-items: center; justify-content: center;
  padding: 1rem;
  backdrop-filter: blur(4px);
}

.modal-overlay.hidden { display: none; }

.modal-box {
  background: var(--bg-modal);
  border: 1px solid var(--border-accent);
  border-radius: var(--radius-xl);
  width: min(600px, 95vw);
  max-height: 88vh;
  display: flex; flex-direction: column;
  box-shadow: var(--shadow-modal);
  overflow: hidden;
}

.modal-box.modal-lg { width: min(820px, 95vw); }
.modal-box.modal-xl { width: min(1000px, 95vw); }

.modal-header {
  padding: 1rem 1.25rem;
  border-bottom: 1px solid var(--border-soft);
  display: flex; align-items: center;
  gap: .75rem;
}

.modal-header h3 {
  flex: 1; font-size: 1rem; font-weight: 700; color: var(--text-accent);
}

.modal-body { flex: 1; overflow-y: auto; padding: 1.25rem; }
.modal-footer {
  padding: .9rem 1.25rem;
  border-top: 1px solid var(--border-soft);
  display: flex; gap: .6rem; justify-content: flex-end;
}

/* ── Tabs ── */
.tabs {
  display: flex; gap: .25rem;
  border-bottom: 1px solid var(--border-soft);
  margin-bottom: 1rem; flex-wrap: wrap;
}

.tab-btn {
  padding: .5rem .9rem; border: none; background: none;
  color: var(--text-secondary); font-family: var(--font-main);
  font-size: .82rem; font-weight: 600; cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all .18s; margin-bottom: -1px;
}

.tab-btn.active {
  color: var(--text-accent);
  border-bottom-color: var(--accent-primary);
}

.tab-btn:hover:not(.active) { color: var(--text-primary); }

.tab-pane { display: none; }
.tab-pane.active { display: block; }

/* ── Toast ── */
#toast-container {
  position: fixed; bottom: 1.5rem; left: 1.5rem;
  z-index: 9990; display: flex; flex-direction: column; gap: .5rem;
}

.toast {
  background: var(--bg-card);
  border: 1px solid var(--border-medium);
  border-radius: var(--radius-md);
  padding: .75rem 1rem;
  font-size: .83rem; font-weight: 600;
  box-shadow: var(--shadow-card);
  display: flex; align-items: center; gap: .6rem;
  animation: slideUp .25s ease; min-width: 220px;
  max-width: 340px;
}

.toast.success { border-color: rgba(16,185,129,.5); color: #10b981; }
.toast.error   { border-color: rgba(239,68,68,.5);  color: #ef4444; }
.toast.info    { border-color: rgba(14,165,233,.5);  color: #0ea5e9; }
.toast.warn    { border-color: rgba(245,158,11,.5);  color: #f59e0b; }

@keyframes slideUp {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Loader ── */
.spinner {
  width: 28px; height: 28px; border-radius: 50%;
  border: 3px solid var(--border-medium);
  border-top-color: var(--accent-primary);
  animation: spin .7s linear infinite;
  margin: auto;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-row td {
  text-align: center; padding: 2rem;
  color: var(--text-muted);
}

/* ── Page-specific helpers ── */
.section-header {
  display: flex; align-items: center;
  justify-content: space-between; flex-wrap: wrap;
  gap: .75rem; margin-bottom: 1rem;
}

.section-header h2 {
  font-size: 1rem; font-weight: 700; color: var(--text-primary);
}

.empty-state {
  text-align: center; padding: 3rem 1rem;
  color: var(--text-muted); font-size: .88rem;
}
.empty-state .empty-icon { font-size: 2.5rem; margin-bottom: .75rem; }

.divider {
  border: none; border-top: 1px solid var(--border-soft);
  margin: 1.25rem 0;
}

/* ── Action Buttons in Table ── */
.action-group { display: flex; gap: .3rem; flex-wrap: nowrap; }

/* ── Grid Layouts ── */
.grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
.grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
.grid-auto { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem; }

@media (max-width: 640px) {
  .grid-2, .grid-3 { grid-template-columns: 1fr; }
  .admin-sidebar { transform: translateX(100%); }
  .admin-sidebar.open { transform: translateX(0); }
  .admin-main { margin-right: 0; }
}

/* ── Dashboard Leaderboard mini ── */
.leaderboard-mini .lb-row {
  display: flex; align-items: center; gap: .6rem;
  padding: .45rem 0;
  border-bottom: 1px solid var(--border-soft);
  font-size: .82rem;
}
.leaderboard-mini .lb-row:last-child { border-bottom: none; }
.lb-rank {
  width: 24px; height: 24px; border-radius: 50%;
  background: var(--bg-surface);
  display: flex; align-items: center; justify-content: center;
  font-size: .72rem; font-weight: 700; color: var(--text-muted);
  flex-shrink: 0;
}
.lb-rank.gold   { background: rgba(245,158,11,.2); color: var(--accent-gold); }
.lb-rank.silver { background: rgba(148,163,184,.2); color: #94a3b8; }
.lb-rank.bronze { background: rgba(180,120,80,.2);  color: #b4a170; }
.lb-name { flex: 1; color: var(--text-primary); font-weight: 500; }
.lb-val  { color: var(--text-accent); font-family: var(--font-mono); font-size: .78rem; font-weight: 700; }

/* ── Checkbox custom ── */
input[type="checkbox"] {
  width: 16px; height: 16px; accent-color: var(--accent-primary);
}

/* ── Scrollbar ── */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border-medium); border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: var(--border-accent); }

/* ── answer cards ── */
.answer-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-soft);
  border-radius: var(--radius-md);
  padding: 1rem; margin-bottom: .75rem;
  transition: border-color .2s;
}
.answer-card.featured { border-color: var(--accent-gold); }
.answer-card.hidden-ans { opacity: .45; }
.answer-card .ans-meta {
  font-size: .74rem; color: var(--text-muted); margin-bottom: .4rem;
  display: flex; gap: .75rem; flex-wrap: wrap;
}
.answer-card .ans-text { font-size: .88rem; line-height: 1.6; }
.answer-card .ans-actions { margin-top: .65rem; display: flex; gap: .4rem; flex-wrap: wrap; }

/* ── Season card ── */
.season-card {
  background: var(--bg-card);
  border: 1px solid var(--border-soft);
  border-radius: var(--radius-lg);
  padding: 1.1rem 1.25rem;
  display: flex; align-items: center; gap: 1rem;
  margin-bottom: .75rem; transition: border-color .2s;
}
.season-card.active-season { border-color: var(--accent-green); }
.season-card .season-info { flex: 1; }
.season-card .season-name { font-weight: 700; font-size: .95rem; }
.season-card .season-dates { font-size: .75rem; color: var(--text-muted); margin-top: .2rem; }

/* ── Doctor group card ── */
.doctor-card {
  background: var(--bg-card);
  border: 1px solid var(--border-soft);
  border-radius: var(--radius-lg);
  padding: 1rem;
  transition: border-color .2s;
}
.doctor-card:hover { border-color: var(--border-accent); }
.doctor-card .dc-header { display: flex; align-items: center; gap: .6rem; margin-bottom: .65rem; }
.doctor-card .dc-name { font-weight: 700; font-size: .95rem; flex: 1; }
.doctor-card .dc-code { font-family: var(--font-mono); font-size: .78rem; color: var(--accent-teal); }
.doctor-card .dc-stats { font-size: .78rem; color: var(--text-secondary); margin-bottom: .75rem; }
.doctor-card .dc-actions { display: flex; gap: .4rem; flex-wrap: wrap; }

/* ── Profile tabs ── */
.profile-tabs-nav { display: flex; gap: .15rem; flex-wrap: wrap; margin-bottom: 1rem; }
.profile-tab-btn {
  padding: .38rem .75rem;
  background: transparent; border: 1px solid var(--border-soft);
  border-radius: var(--radius-sm);
  color: var(--text-secondary); font-family: var(--font-main);
  font-size: .78rem; font-weight: 600; cursor: pointer; transition: all .15s;
}
.profile-tab-btn.active {
  background: var(--accent-primary); border-color: var(--accent-primary);
  color: #fff;
}

/* ── Text helpers ── */
.text-green  { color: var(--accent-green); }
.text-red    { color: var(--accent-red); }
.text-yellow { color: var(--accent-gold); }
.text-blue   { color: var(--accent-teal); }
.text-purple { color: var(--text-accent); }
.text-muted  { color: var(--text-muted); }
.text-sm     { font-size: .78rem; }
.text-xs     { font-size: .72rem; }
.font-mono   { font-family: var(--font-mono); }
.fw-bold     { font-weight: 700; }
.mt-1 { margin-top: .5rem; }
.mt-2 { margin-top: 1rem; }
.mb-1 { margin-bottom: .5rem; }
.mb-2 { margin-bottom: 1rem; }
.gap-sm { gap: .4rem; }
.flex { display: flex; }
.flex-center { display: flex; align-items: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
